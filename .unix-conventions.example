# .unix-conventions
# Per-project configuration for the unix-conventions skill.
# Place this file at the root of a project to resolve conflicts between
# POSIX, GNU Coding Standards, and TAOUP where they disagree.
#
# For each setting, the options are listed after the =.
# Leave a value blank (or omit the line) to be prompted when it arises.

# Which standard takes precedence globally when they conflict.
# posix | gnu | ask
standard = ask

# Whether -h is reserved for --help (GNU) or available for domain use
# (e.g., human-readable sizes as in ls -h, df -h).
# help | domain | ask
short_h = ask

# Whether to require GNU-style long options (--foo) alongside POSIX short
# options (-f), or treat them as optional/unnecessary.
# require | optional | none | ask
long_options = ask

# Whether options may appear after operands (GNU permutation behaviour),
# or whether the first non-option argument ends option parsing (POSIX strict).
# yes | no | ask
options_after_operands = ask

# Preferred shebang for shell scripts. Use sh for POSIX portability; bash
# when bash-specific features (arrays, [[ ]], pipefail, etc.) are used.
# sh | bash | ask
shebang = ask

# Preferred output command in shell scripts.
# printf is more portable; echo is more readable but has implementation-
# defined behaviour with -n and backslash escapes.
# printf | echo | ask
echo_or_printf = ask

# C indentation style.
# gnu=2 spaces, kr=8-space tabs (K&R), linux=8-space tabs (Linux kernel rules)
# gnu | kr | linux | ask
c_indent = ask

# Whether to use glibc's error()/error_at_line() functions (GNU recommendation).
# Not portable outside glibc. Only relevant for C programs.
# yes | no | ask
glibc_error = ask

# Whether to apply the "Worse is Better" design lens during design reviews.
# yes = always apply it; no = skip it; ask = prompt when a design tradeoff arises.
# yes | no | ask
worse_is_better = ask
